# ChatARPES Environment Configuration
# Copy this to .env and fill in values

# LLM Provider: "anthropic", "local", or "berkeley"
LLM_PROVIDER=anthropic

# Anthropic API Key (if using Option B or C)
# PLACEHOLDER: Need to confirm API access with lab lead
# Berkeley Lab may provide AI access - check if API tokens available
ANTHROPIC_API_KEY=

# Model: claude-haiku-4-5-20251001 (recommended) or claude-sonnet-4-6-20250514
LLM_MODEL=claude-haiku-4-5-20251001

# Auth: "google_oauth", "passphrase", "calnet", "none"
AUTH_METHOD=none
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Hosting
# PLACEHOLDER: Confirm domain with lab lead
# TARGET_DOMAIN=chatarpes.berkeley.edu
